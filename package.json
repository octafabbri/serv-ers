    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.1.0",
    "lucide-react": "^0.487.0",
    "motion": "^12.23.24",
    "ms": "^2.1.3",
    "openai": "^6.18.0",
    "pg": "^8.20.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "scheduler": "^0.27.0"
  },
